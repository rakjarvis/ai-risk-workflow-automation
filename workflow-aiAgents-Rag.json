    {
      "parameters": {
        "jsCode": "const message = ($json.message || \"\").toLowerCase();\nconst text = ($json.policy_text || \"\").toLowerCase();\n\nlet context = [];\n\nif (!message) {\n  throw new Error(\"message is missing from input\");\n}\n\n// simple section-based matching\nif (message.includes(\"claim\")) {\n  const match = text.match(/claims policy[\\s\\S]*?(?=cyber policy|complaint policy|$)/i);\n  if (match) context.push(match[0]);\n}\n\nif (message.includes(\"breach\") || message.includes(\"cyber\") || message.includes(\"data\")) {\n  const match = text.match(/cyber incident policy[\\s\\S]*?(?=claims policy|complaint policy|$)/i);\n  if (match) context.push(match[0]);\n}\n\nif (message.includes(\"complaint\")) {\n  const match = text.match(/complaint handling policy[\\s\\S]*$/i);\n  if (match) context.push(match[0]);\n}\n\nif (context.length === 0) {\n  context.push(\"No specific policy matched. Use general insurance reasoning.\");\n}\n\nreturn [{\n  json: {\n    ...$json,\n    rag_context: context.join(\"\\n\\n\")\n  }\n}];"
      },
